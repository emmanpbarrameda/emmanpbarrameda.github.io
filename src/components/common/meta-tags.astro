---
import { infos } from "../../data/infos.js";

interface Props {
  title?: string;
  description?: string;
  url?: string;
  image?: string;
  ogType?: string;
}

const { title = infos.og_title, description = infos.og_description, url = infos.host, image = infos.og_image, ogType = "website" } = Astro.props;

const ogImage = image ? new URL(image, Astro.site).toString() : new URL(infos.og_image, Astro.site).toString();

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    // ── 1. PERSON ──────────────────────────────────────────────
    {
      "@type": "Person",
      "@id": `${infos.host}/#person`,
      name: infos.fullname,
      alternateName: [infos.subname, infos.nickname],
      url: infos.host,
      image: {
        "@type": "ImageObject",
        url: ogImage,
        width: 1200,
        height: 630
      },
      description: description,
      email: infos.email,
      sameAs: [infos.github, infos.linkedin, infos.twitter, infos.facebook, infos.googledev, infos.wakatime].filter(Boolean),
      knowsAbout: ["Laravel", "FilamentPHP", "Livewire", "Alpine.js", "Tailwind CSS", "PHP", "MySQL", "Backend Development", "Full Stack Development", "REST API Development", "Leadership", "Project Management"],
      knowsLanguage: [
        {
          "@type": "Language",
          name: "English"
        },
        {
          "@type": "Language",
          name: "Filipino"
        }
      ],
      nationality: {
        "@type": "Country",
        name: "Philippines"
      },
      address: {
        "@type": "PostalAddress",
        addressCountry: "PH"
      },

      worksFor: {
        "@type": "Organization",
        name: "Self-Employed"
      },

      jobTitle: infos.job_title,
      hasOccupation: {
        "@type": "Occupation",
        name: infos.job_title,
        occupationLocation: {
          "@type": "Country",
          name: "Philippines"
        }
      }
    },

    // ── 2. WEBSITE ─────────────────────────────────────────────
    {
      "@type": "WebSite",
      "@id": `${infos.host}/#website`,
      url: infos.host,
      name: title,
      description: description,
      author: {
        "@id": `${infos.host}/#person`
      },
      // SearchAction — enables Google Sitelinks Search Box
      potentialAction: {
        "@type": "SearchAction",
        target: {
          "@type": "EntryPoint",
          urlTemplate: `${infos.host}/${infos.blog_page_slug}?q={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    },

    // ── 3. WEBPAGE ─────────────────────────────────────────────
    {
      "@type": "WebPage",
      "@id": `${url}#webpage`,
      url: url,
      name: title,
      description: description,
      isPartOf: {
        "@id": `${infos.host}/#website`
      },
      about: {
        "@id": `${infos.host}/#person`
      }
    },

    // ── 4. PROFILE PAGE ────────────────────────────────────────
    {
      "@type": "ProfilePage",
      "@id": `${infos.host}/#profilepage`,
      url: infos.host,
      name: title,
      description: description,
      mainEntity: {
        "@id": `${infos.host}/#person`
      },
      isPartOf: {
        "@id": `${infos.host}/#website`
      }
    },

    // ── 5. BREADCRUMBLIST ──────────────────────────────────────
    {
      "@type": "BreadcrumbList",
      "@id": `${infos.host}/#breadcrumb`,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: infos.host
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Projects",
          item: `${infos.host}/#projects`
        },
        {
          "@type": "ListItem",
          position: 3,
          name: infos.blog_page_name,
          item: `${infos.host}/${infos.blog_page_slug}`
        },
        {
          "@type": "ListItem",
          position: 4,
          name: "Socials",
          item: `${infos.host}/socials`
        }
      ]
    }
  ]
};
---

<!-- Icon -->
<link rel="icon" type="image/x-icon" href="/favicon.ico" />

<meta name="generator" content={Astro.generator} />
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />

<!-- Canonical -->
<link rel="canonical" href={url} />

<!-- RSS + Sitemap -->
<link rel="alternate" type="application/rss+xml" title={`${infos.fullname} Blog RSS`} href="/rss.xml" />
<link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />

<!-- Identity -->
<link rel="me" href={infos.github} />
<link rel="me" href={infos.linkedin} />
<link rel="me" href={infos.twitter} />
<link rel="me" href={infos.googledev} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={url} />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={`${infos.fullname} Portfolio`} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:site" content={`@${infos.username}`} />
<meta name="twitter:creator" content={`@${infos.username}`} />

<!-- Google -->
<meta itemprop="name" content={title} />
<meta itemprop="description" content={description} />

<!-- SEO -->
<meta name="description" content={description} />
<meta name="author" content={infos.fullname} />
<meta name="robots" content="index, follow" />

<meta property="og:image" content={ogImage} />
<meta name="twitter:image" content={ogImage} />
<meta itemprop="image" content={ogImage} />

<!-- Google Search Console -->
<meta name="google-site-verification" content="BvLhWKwhecxLYc5G0eZb0XKjIe-GfPD7R_Ly5BxIGZw" />

<!-- JSON-LD Schema Markup -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
