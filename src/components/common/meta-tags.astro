---
import { infos } from "../../data/infos.js";

interface Props {
  title?: string;
  description?: string;
  url?: string;
  image?: string;
}

const { title = infos.og_title, description = infos.og_description, url = infos.host, image = infos.og_image } = Astro.props;

const ogImage = image ? new URL(image, Astro.site).toString() : new URL(infos.og_image, Astro.site).toString();

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${infos.host}/#person`,
      name: infos.fullname,
      url: infos.host,
      image: {
        "@type": "ImageObject",
        url: ogImage,
        width: 1200,
        height: 630
      },
      jobTitle: infos.job_title,
      description: description,
      email: infos.email,
      sameAs: [infos.github, infos.linkedin, infos.twitter].filter(Boolean)
    },
    {
      "@type": "WebSite",
      "@id": `${infos.host}/#website`,
      url: infos.host,
      name: title,
      description: description,
      author: {
        "@id": `${infos.host}/#person`
      }
    },
    {
      "@type": "WebPage",
      "@id": `${url}#webpage`,
      url: url,
      name: title,
      description: description,
      isPartOf: {
        "@id": `${infos.host}/#website`
      },
      about: {
        "@id": `${infos.host}/#person`
      }
    }
  ]
};
---

<!-- icon and main title -->
<link rel="icon" type="image/x-icon" href="/favicon.ico" />

<meta name="generator" content={Astro.generator} />
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />

<!-- Canonical -->
<link rel="canonical" href={url} />

<!-- RSS + Sitemap -->
<link rel="alternate" type="application/rss+xml" title={`${infos.fullname} Blog RSS`} href="/rss.xml" />
<link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap-index.xml" />

<!--==================== OPEN GRAPH META TAGS (FOR SOCIAL MEDIA PREVIEW) ===================== -->
<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={url} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content={`${infos.fullname} Portfolio`} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:site" content={`@${infos.username}`} />
<meta name="twitter:creator" content={`@${infos.username}`} />

<!-- Google -->
<meta itemprop="name" content={title} />
<meta itemprop="description" content={description} />

<!-- SEO -->
<meta name="description" content={description} />
<meta name="author" content={infos.fullname} />
<meta name="robots" content="index" />

<meta property="og:image" content={ogImage} />
<meta name="twitter:image" content={ogImage} />
<meta itemprop="image" content={ogImage} />

<!-- Google Search Console Verification -->
<meta name="google-site-verification" content="BvLhWKwhecxLYc5G0eZb0XKjIe-GfPD7R_Ly5BxIGZw" />

<!-- JSON-LD Schema Markup -->
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
